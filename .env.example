# PostgreSQL connection strings (Neon).
# Get both from the Neon dashboard: Project -> Connect -> Connection string.

# Pooled connection string (goes through Neon's connection pooler).
# Used by the app at runtime.
# Example format:
# postgresql://<user>:<password>@<endpoint>-pooler.<region>.neon.tech/<database>?sslmode=require
DATABASE_URL=""

# Direct (unpooled) connection string, bypassing the pooler.
# Used by the Prisma CLI for migrations and introspection.
# Same format, without the "-pooler" suffix in the host:
# postgresql://<user>:<password>@<endpoint>.<region>.neon.tech/<database>?sslmode=require
DIRECT_URL=""
