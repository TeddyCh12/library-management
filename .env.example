# PostgreSQL connection strings (Neon).
# Get both from the Neon dashboard: Project -> Connect -> Connection string.

# Pooled connection string (goes through Neon's connection pooler).
# Used by the app at runtime.
# Example format:
# postgresql://<user>:<password>@<endpoint>-pooler.<region>.neon.tech/<database>?sslmode=verify-full
DATABASE_URL=""

# Direct (unpooled) connection string, bypassing the pooler.
# Used by the Prisma CLI for migrations and introspection.
# Same format, without the "-pooler" suffix in the host:
# postgresql://<user>:<password>@<endpoint>.<region>.neon.tech/<database>?sslmode=verify-full
DIRECT_URL=""

# Auth.js session encryption secret (required).
# Generate one with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=""

# Google OAuth (optional locally — the Google sign-in button only appears
# when both are set; demo credential login works without them).
# Create at https://console.cloud.google.com/apis/credentials with redirect
# URI <origin>/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
